# SentinelIQ backend config — copy to .env and fill in.
PORT=5000
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=change-me-in-production

# Postgres (leave unset on Day 1 — server runs without a DB).
# Example: postgresql://user:password@localhost:5432/sentineliq
# DATABASE_URL=

# Anthropic Claude API (Builder C NLP classifier)
ANTHROPIC_API_KEY=
NLP_MODEL=claude-sonnet-4-6
