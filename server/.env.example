# SentinelIQ backend config — copy to .env and fill in.
PORT=5000
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=change-me-in-production

# Postgres — required. A free serverless instance (e.g. Neon) works fine.
# Example: postgresql://user:password@localhost:5432/sentineliq
DATABASE_URL=

# Google Gemini API (scam-message NLP classifier). Originally spec'd for the
# Claude API; switched to Gemini during the hackathon build due to Anthropic
# account credit constraints — the prompt/schema/tests are model-agnostic.
GEMINI_API_KEY=
NLP_MODEL=gemini-2.5-flash
